{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/app/[lng]/layout.jsx",
    "src/app/[lng]/components/Navbar.jsx",
    "src/app/[lng]/components/Animation.jsx",
    "src/app/[lng]/components/Strawhat_duck.jsx",
    "src/middleware.js",
    "src/i18n/routing.js",
    "src/i18n/request.js",
    "src/app/[lng]/page.jsx"
  ],
  "exclude": [
    "node_modules"
  ]
}